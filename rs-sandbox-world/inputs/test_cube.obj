# Unit cube centered at origin, 12 triangles (simple RS normalization fixture).
o test_cube
v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0
v -1.0  1.0 -1.0
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0  1.0
# brown/grey per-face colors via material off — vertex colors not in OBJ; use usemtl
mtllib test_cube.mtl
usemtl cube_grey
f 1 2 3
f 1 3 4
f 5 6 7
f 5 7 8
f 1 5 8
f 1 8 4
f 2 6 7
f 2 7 3
f 1 2 6
f 1 6 5
f 4 3 7
f 4 7 8
