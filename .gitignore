# Local environment
.env
.env.local
.env.*
!.env.example

# Game cache (user-provided; see README)
/cache/*
!cache/.gitkeep
/rs-sandbox-world/cache/*
!rs-sandbox-world/cache/.gitkeep

# Documentation — root README only
*.md
!/README.md

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
**/_vendor/

# Generated outputs
rs-sandbox-world/outputs/
rs-sandbox-world/exports/
rs-sandbox-world/.pytest_cache/

# IDE / OS
.cursor/
.cursorignore
.DS_Store
Thumbs.db
*.log
serve_log*.txt

# Optional local checkouts kept alongside the repo (not part of RuneBox)
RuneScape-317-client/
elvarg-rsps-master/
concepts/
cache-runescape*/
apollo-kotlin-experiments/
tools/
